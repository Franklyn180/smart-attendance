# GROUP 9 — LOCAL ENVIRONMENT CONFIGURATION TEMPLATE
# Smart Attendance Management System
# DO NOT commit your real .env file to Github. This is the template only.

# Database Connection Topology
DB_HOST=database
DB_NAME=app_db
DB_USER=app_user

# Database Authentication Credentials
# WARNING: Change these values in production! Never use default credentials.
DB_PASSWORD=your-secure-password-here
DB_ROOT_PASSWORD=your-secure-root-password-here
MYSQL_ROOT_PASSWORD=your-secure-root-password-here

# JWT Secret Key for token authentication
# SECURITY: Generate a strong random string for production
JWT_SECRET_KEY=your-secure-jwt-secret-key-here

# API Configuration
VITE_API_URL=
BACKEND_PORT=8000
FRONTEND_PORT=5173
